# Banco de dados
DATABASE_URL=postgresql://user:password@localhost:5432/kotodama

# Redis (cache + filas BullMQ)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=troque-isso-por-uma-string-aleatoria-muito-longa
JWT_EXPIRES_IN=7d

# Criptografia AES-256-CBC para tokens da Meta (chave em hex de 64 chars = 32 bytes)
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Meta / WhatsApp
META_VERIFY_TOKEN=token-global-verificacao-webhook-meta

# App
NODE_ENV=development
API_PORT=3001
FRONTEND_URL=http://localhost:3000

# Storage de arquivos
UPLOAD_PATH=./uploads
MAX_FILE_SIZE_MB=10

# Admin inicial (seed)
ADMIN_EMAIL=admin@seichonoie.org.br
ADMIN_PASSWORD=ChangeMe123!
ADMIN_NAME=Administrador
